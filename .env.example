# ── Supabase (auth + cloud database) ──
# Project Settings → API. These are PUBLIC client keys (safe in the browser).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── NVIDIA model API (server-side only; set in Vercel, NOT prefixed with VITE_) ──
# OPENAI_API_KEY=nvapi-...
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=meta/llama-3.3-70b-instruct
