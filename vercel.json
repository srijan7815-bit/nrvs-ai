{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/run.js": { "maxDuration": 60 },
    "api/serve.js": { "maxDuration": 60 },
    "api/flow.js": { "maxDuration": 60 },
    "api/flow-exec.js": { "maxDuration": 60 },
    "api/memory-extract.js": { "maxDuration": 30 }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
